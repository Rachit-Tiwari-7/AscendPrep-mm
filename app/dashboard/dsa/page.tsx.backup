'use client';

import { useState } from 'react';
import { useQuery, useMutation, useQueryClient } from '@tanstack/react-query';
import { motion } from 'framer-motion';
import { 
  Code2, Play, CheckCircle2, Clock, Lightbulb, BookOpen, BarChart3, Target,
  ChevronDown, ChevronUp, Loader2, RotateCcw, Trash2, AlertCircle, Sparkles,
  Brain, Zap, Trophy, Flame, ExternalLink
} from 'lucide-react';
import { toast } from 'sonner';
import { dsaApi, DSAQuestion, DSAAnalytics } from './api';
import { resumeIntelligenceApi, ResumeDashboardStats } from '../resume-intelligence/api';
import { DSAQuestionCard } from './question-card';
import { FadeIn, FadeInUp, StaggerContainer, StaggerItem } from '@/components/animations';
import { getRandomQuestion, PATTERN_NAMES, PatternQuestion, ALL_QUESTIONS } from './question-bank';

const TOPIC_ICONS: Record<string, string> = {
  arrays: '[]', strings: '""', linked_list: '→', trees: 'T', graphs: 'G',
  dynamic_programming: 'DP', sorting: '⇅', searching: 'S', hash_table: '{}',
  heap: 'H', stack: 'ST', queue: 'Q', backtracking: 'BK', bit_manipulation: 'BM', math: '∑',
};

const DIFFICULTY_STYLES: Record<string, string> = {
  easy: 'bg-emerald-100 text-emerald-700 border-2 border-emerald-900',
  medium: 'bg-amber-100 text-amber-700 border-2 border-amber-900',
  hard: 'bg-rose-100 text-rose-700 border-2 border-rose-900',
};

const FALLBACK_TOPICS: Record<string, { patterns: string[]; techniques: string[] }> = {
  arrays: { patterns: ['sliding_window', 'two_pointers', 'prefix_sum'], techniques: ['traversing_from_right'] },
  strings: { patterns: ['sliding_window', 'two_pointers'], techniques: ['character_counting'] },
  linked_list: { patterns: ['fast_slow_pointers', 'reversal'], techniques: ['dummy_head_node'] },
  trees: { patterns: ['dfs', 'bfs'], techniques: ['level_order'] },
  graphs: { patterns: ['dfs', 'bfs'], techniques: ['adjacency_list'] },
  dynamic_programming: { patterns: ['memoization', 'tabulation'], techniques: ['bottom_up'] },
  sorting: { patterns: ['merge_sort', 'quick_sort'], techniques: ['custom_comparator'] },
  searching: { patterns: ['binary_search'], techniques: ['search_space_reduction'] },
  hash_table: { patterns: ['frequency_count', 'two_sum_pattern'], techniques: ['hash_map'] },
  heap: { patterns: ['min_heap', 'max_heap'], techniques: ['priority_queue'] },
  stack: { patterns: ['monotonic_stack'], techniques: ['next_greater'] },
  queue: { patterns: ['bfs', 'deque'], techniques: ['sliding_window_max'] },
  backtracking: { patterns: ['permutations', 'combinations'], techniques: ['pruning'] },
  bit_manipulation: { patterns: ['xor', 'bitmasking'], techniques: ['single_number'] },
  math: { patterns: ['gcd', 'lcm'], techniques: ['modular_arithmetic'] },
};

const SAMPLE_QUESTIONS: Record<string, Record<string, any[]>> = {
  arrays: {
    easy: [
      {
        title: 'Two Sum',
        description: 'Given an array of integers nums and an integer target, return indices of the two numbers such that they add up to target.',
        example_input: 'nums = [2,7,11,15], target = 9',
        example_output: '[0,1]',
        constraints: '2 <= nums.length <= 10^4',
        hints: ['Use a hash map to store visited numbers', 'Check if target - current exists in map'],
        solution_approach: 'Hash Map - O(n) time',
        solution_code: 'function twoSum(nums, target) {\n  const map = new Map();\n  for (let i = 0; i < nums.length; i++) {\n    const complement = target - nums[i];\n    if (map.has(complement)) return [map.get(complement), i];\n    map.set(nums[i], i);\n  }\n}'
      }
    ],
    medium: [
      {
        title: 'Maximum Subarray',
        description: 'Find the contiguous subarray with the largest sum and return its sum.',
        example_input: 'nums = [-2,1,-3,4,-1,2,1,-5,4]',
        example_output: '6',
        constraints: '1 <= nums.length <= 10^5',
        hints: ['Use Kadane\'s algorithm', 'Track current sum and max sum'],
        solution_approach: 'Kadane\'s Algorithm - O(n)',
        solution_code: 'function maxSubArray(nums) {\n  let maxSum = nums[0], currSum = nums[0];\n  for (let i = 1; i < nums.length; i++) {\n    currSum = Math.max(nums[i], currSum + nums[i]);\n    maxSum = Math.max(maxSum, currSum);\n  }\n  return maxSum;\n}'
      }
    ],
    hard: [
      {
        title: 'Trapping Rain Water',
        description: 'Given n non-negative integers representing elevation map, compute how much water it can trap.',
        example_input: 'height = [0,1,0,2,1,0,1,3,2,1,2,1]',
        example_output: '6',
        constraints: '1 <= n <= 2 * 10^4',
        hints: ['Use two pointers', 'Track max left and right'],
        solution_approach: 'Two Pointers - O(n)',
        solution_code: 'function trap(height) {\n  let left = 0, right = height.length - 1, maxLeft = 0, maxRight = 0, water = 0;\n  while (left < right) {\n    if (height[left] < height[right]) {\n      height[left] >= maxLeft ? maxLeft = height[left] : water += maxLeft - height[left];\n      left++;\n    } else {\n      height[right] >= maxRight ? maxRight = height[right] : water += maxRight - height[right];\n      right--;\n    }\n  }\n  return water;\n}'
      }
    ]
  },
  strings: {
    easy: [
      {
        title: 'Valid Anagram',
        description: 'Given two strings s and t, return true if t is an anagram of s.',
        example_input: 's = "anagram", t = "nagaram"',
        example_output: 'true',
        constraints: '1 <= s.length <= 5 * 10^4',
        hints: ['Use frequency count', 'Compare character counts'],
        solution_approach: 'Hash Map - O(n)',
        solution_code: 'function isAnagram(s, t) {\n  if (s.length !== t.length) return false;\n  const count = {};\n  for (let c of s) count[c] = (count[c] || 0) + 1;\n  for (let c of t) {\n    if (!count[c]) return false;\n    count[c]--;\n  }\n  return true;\n}'
      }
    ],
    medium: [
      {
        title: 'Longest Palindromic Substring',
        description: 'Given a string s, return the longest palindromic substring.',
        example_input: 's = "babad"',
        example_output: '"bab"',
        constraints: '1 <= s.length <= 1000',
        hints: ['Expand around center', 'Check odd and even length'],
        solution_approach: 'Expand Around Center - O(n²)',
        solution_code: 'function longestPalindrome(s) {\n  let start = 0, maxLen = 0;\n  for (let i = 0; i < s.length; i++) {\n    expand(i, i); expand(i, i + 1);\n  }\n  function expand(l, r) {\n    while (l >= 0 && r < s.length && s[l] === s[r]) {\n      if (r - l + 1 > maxLen) { start = l; maxLen = r - l + 1; }\n      l--; r++;\n    }\n  }\n  return s.substring(start, start + maxLen);\n}'
      }
    ],
    hard: [
      {
        title: 'Regular Expression Matching',
        description: 'Given string s and pattern p, implement regular expression matching.',
        example_input: 's = "aa", p = "a*"',
        example_output: 'true',
        constraints: '1 <= s.length <= 20',
        hints: ['Use dynamic programming', 'Handle * as zero or more'],
        solution_approach: 'DP - O(m*n)',
        solution_code: 'function isMatch(s, p) {\n  const dp = Array(s.length + 1).fill().map(() => Array(p.length + 1).fill(false));\n  dp[0][0] = true;\n  for (let j = 1; j <= p.length; j++) {\n    if (p[j-1] === "*") dp[0][j] = dp[0][j-2];\n  }\n  for (let i = 1; i <= s.length; i++) {\n    for (let j = 1; j <= p.length; j++) {\n      if (p[j-1] === "." || p[j-1] === s[i-1]) dp[i][j] = dp[i-1][j-1];\n      else if (p[j-1] === "*") {\n        dp[i][j] = dp[i][j-2] || ((p[j-2] === "." || p[j-2] === s[i-1]) && dp[i-1][j]);\n      }\n    }\n  }\n  return dp[s.length][p.length];\n}'
      }
    ]
  }
};

const generateMockQuestion = (topic: string, difficulty: string): DSAQuestion => {
  const questions = SAMPLE_QUESTIONS[topic]?.[difficulty] || [];
  const q = questions[Math.floor(Math.random() * questions.length)] || {
    title: `${topic.replace('_', ' ').replace(/\b\w/g, l => l.toUpperCase())} Problem`,
    description: `Practice ${topic} at ${difficulty} level.`,
    example_input: 'N/A',
    example_output: 'N/A',
    constraints: 'Standard constraints',
    hints: ['Think about patterns'],
    solution_approach: 'Approach varies',
    solution_code: '// Code here'
  };
  return {
    id: Date.now() + Math.floor(Math.random() * 1000),
    user_id: 0,
    topic,
    difficulty: difficulty as 'easy' | 'medium' | 'hard',
    created_at: new Date().toISOString(),
    updated_at: new Date().toISOString(),
    ...q
  };
};

export default function DSAPage() {
  const [selectedTopic, setSelectedTopic] = useState<string>('');
  const [selectedDifficulty, setSelectedDifficulty] = useState<string>('');
  const [activeTab, setActiveTab] = useState<string>('practice');
  const [expandedHints, setExpandedHints] = useState<Set<number>>(new Set());
  const [showSolution, setShowSolution] = useState<Set<number>>(new Set());
  const queryClient = useQueryClient();

  const { data: topicsData, isLoading: topicsLoading, error: topicsError } = useQuery({
    queryKey: ['dsa-topics'],
    queryFn: () => dsaApi.getTopics(),
  });

  const { data: questions, isLoading: questionsLoading } = useQuery<DSAQuestion[]>({
    queryKey: ['dsa-questions'],
    queryFn: async () => {
      // Read from localStorage - no backend needed
      const storedQuestions = JSON.parse(localStorage.getItem('dsa-generated-questions') || '[]');
      return storedQuestions;
    },
  });

  const { data: analytics, isLoading: analyticsLoading } = useQuery<DSAAnalytics>({
    queryKey: ['dsa-analytics'],
    queryFn: () => dsaApi.getAnalytics(),
  });

  const { data: resumeStats } = useQuery<ResumeDashboardStats>({
    queryKey: ['resume-dashboard-stats'],
    queryFn: () => resumeIntelligenceApi.getDashboardStats(),
  });

  const generateMutation = useMutation({
    mutationFn: async (data: { topic: string; difficulty: string }) => {
      // Use local question bank instead of broken backend
      const question = getRandomQuestion(data.topic, data.difficulty);
      
      // Convert PatternQuestion to DSAQuestion format
      const dsaQuestion: DSAQuestion & { leetCodeUrl?: string } = {
        id: Date.now(), // Generate temporary ID
        title: question.title,
        difficulty: question.difficulty,
        topic: question.topic,
        problem_description: question.problem_description,
        constraints: question.constraints,
        example_input: question.example_input,
        example_output: question.example_output,
        hints: question.hints,
        solution_explanation: question.solution_explanation,
        leetCodeUrl: (question as any).leetCodeUrl, // Include LeetCode URL
        created_at: new Date().toISOString(),
      };
      
      // Store in localStorage for persistence
      const existing = JSON.parse(localStorage.getItem('dsa-generated-questions') || '[]');
      existing.unshift(dsaQuestion);
      localStorage.setItem('dsa-generated-questions', JSON.stringify(existing.slice(0, 50))); // Keep last 50
      
      return dsaQuestion;
    },
    onSuccess: () => {
      toast.success('New question generated!');
      queryClient.invalidateQueries({ queryKey: ['dsa-questions'] });
      setActiveTab('questions');
    },
    onError: (error: any) => toast.error(error.message || 'Failed to generate'),
  });

  // Complete mutation - mark question as done
  const completeMutation = useMutation({
    mutationFn: (id: number) => {
      const questions = JSON.parse(localStorage.getItem('dsa-generated-questions') || '[]');
      const updated = questions.map((q: any) => 
        q.id === id ? { ...q, is_completed: true, completed_at: new Date().toISOString() } : q
      );
      localStorage.setItem('dsa-generated-questions', JSON.stringify(updated));
      return Promise.resolve({ id, is_completed: true });
    },
    onSuccess: () => {
      toast.success('Question marked as complete!');
      queryClient.invalidateQueries({ queryKey: ['dsa-questions'] });
    },
  });

  // Delete mutation - remove question
  const deleteMutation = useMutation({
    mutationFn: (id: number) => {
      const questions = JSON.parse(localStorage.getItem('dsa-generated-questions') || '[]');
      const filtered = questions.filter((q: any) => q.id !== id);
      localStorage.setItem('dsa-generated-questions', JSON.stringify(filtered));
      return Promise.resolve({ id });
    },
    onSuccess: () => {
      toast.success('Question removed');
      queryClient.invalidateQueries({ queryKey: ['dsa-questions'] });
    },
  });

  const handleGenerate = () => {
    if (!selectedTopic || !selectedDifficulty) {
      toast.error('Please select both topic and difficulty');
      return;
    }
    generateMutation.mutate({ topic: selectedTopic, difficulty: selectedDifficulty });
  };

  const topics = topicsData?.topics || FALLBACK_TOPICS;
  const difficultyLevels = topicsData?.difficulty_levels || ['easy', 'medium', 'hard'];

  const stats = analytics?.stats || {
    total_questions_attempted: 0, total_questions_completed: 0, topics_practiced: [],
    difficulty_distribution: { easy: 0, medium: 0, hard: 0 },
  };

  const completionRate = stats.total_questions_attempted > 0
    ? Math.round((stats.total_questions_completed / stats.total_questions_attempted) * 100)
    : 0;

  const statCards = [
    { label: 'Attempted', value: stats.total_questions_attempted, icon: Target, color: 'bg-primary/10', rotate: 'tilt-hover-1' },
    { label: 'Completed', value: stats.total_questions_completed, icon: CheckCircle2, color: 'bg-emerald-100', rotate: 'tilt-hover-2' },
    { label: 'Topics', value: stats.topics_practiced.length, icon: BookOpen, color: 'bg-amber-100', rotate: 'tilt-hover-4' },
    { label: 'Success Rate', value: `${completionRate}%`, icon: Trophy, color: 'bg-rose-100', rotate: 'tilt-hover-1' },
  ];

  return (
    <div className="min-h-screen bg-white pb-20 noise-overlay pt-20">
      <div className="container mx-auto px-4 py-8">
        {/* Header */}
        <FadeIn>
          <div className="flex flex-col md:flex-row md:items-center md:justify-between gap-4 mb-8">
            <div>
              <h1 className="text-4xl md:text-5xl font-black text-gray-900 mb-2">
                DSA <span className="text-primary">Practice</span>
              </h1>
              <p className="text-lg text-gray-600 font-medium">
                Master algorithms with AI-generated interview questions
              </p>
            </div>
            <div className="flex items-center gap-2 brutalist-card p-3 rounded-xl transform rotate-1">
              <Flame className="w-6 h-6 text-orange-500" />
              <span className="font-black text-lg">{stats.total_questions_completed} Solved</span>
            </div>
          </div>
        </FadeIn>

        {/* Stats */}
        <StaggerContainer className="grid gap-4 md:grid-cols-2 lg:grid-cols-4 mb-8" staggerDelay={0.05}>
          {statCards.map((stat, index) => (
            <StaggerItem key={index}>
              <motion.div 
                whileHover={{ rotate: 0, y: -6 }}
                className={`brutalist-card p-4 ${stat.rotate} tilt-hover-straighten`}
              >
                <div className="flex items-center justify-between mb-2">
                  <span className="text-xs font-black uppercase tracking-wider text-gray-500">{stat.label}</span>
                  <div className={`w-10 h-10 ${stat.color} border-2 border-gray-900 flex items-center justify-center`}>
                    <stat.icon className="w-5 h-5 text-gray-700" />
                  </div>
                </div>
                <div className="text-3xl font-black">{analyticsLoading ? <div className="h-8 w-16 bg-gray-200 animate-pulse" /> : stat.value}</div>
              </motion.div>
            </StaggerItem>
          ))}
        </StaggerContainer>

        {/* Recommended Topics */}
        {resumeStats?.recommended_dsa_topics && resumeStats.recommended_dsa_topics.length > 0 && (
          <FadeInUp className="mb-8">
            <div className="brutalist-card-primary p-6 rounded-xl">
              <div className="flex items-center gap-3 mb-4">
                <div className="w-12 h-12 bg-amber-100 border-2 border-gray-900 flex items-center justify-center">
                  <Sparkles className="w-6 h-6 text-amber-600" />
                </div>
                <div>
                  <h3 className="text-xl font-black">Recommended For You</h3>
                  <p className="text-sm text-gray-600 font-medium">Based on your resume analysis</p>
                </div>
              </div>
              <div className="flex flex-wrap gap-2">
                {resumeStats.recommended_dsa_topics.map((topic) => (
                  <button
                    key={topic}
                    onClick={() => { setSelectedTopic(topic); toast.info(`Selected ${topic}`); }}
                    className="px-4 py-2 bg-white border-2 border-gray-900 shadow-[3px_3px_0px_0px_#000] hover:translate-x-[2px] hover:translate-y-[2px] hover:shadow-none transition-all font-bold"
                  >
                    <span className="mr-1">{TOPIC_ICONS[topic] || '•'}</span>
                    {topic.replace('_', ' ')}
                  </button>
                ))}
              </div>
            </div>
          </FadeInUp>
        )}

        {/* Tabs */}
        <div className="brutalist-card p-2 rounded-xl mb-6">
          <div className="flex gap-2">
            {['practice', 'questions', 'analytics'].map((tab) => (
              <button
                key={tab}
                onClick={() => setActiveTab(tab)}
                className={`flex-1 py-3 px-4 font-black uppercase text-sm tracking-wider transition-all ${
                  activeTab === tab 
                    ? 'bg-primary text-white border-2 border-gray-900 shadow-[3px_3px_0px_0px_#000]' 
                    : 'bg-white border-2 border-gray-200 hover:border-gray-900'
                }`}
              >
                {tab === 'practice' && <Play className="w-4 h-4 inline mr-2" />}
                {tab === 'questions' && <Code2 className="w-4 h-4 inline mr-2" />}
                {tab === 'analytics' && <BarChart3 className="w-4 h-4 inline mr-2" />}
                {tab}
              </button>
            ))}
          </div>
        </div>

        {/* Practice Tab */}
        {activeTab === 'practice' && (
          <FadeInUp>
            <div className="brutalist-card p-8 rounded-xl">
              <h2 className="text-2xl font-black mb-6 flex items-center gap-3">
                <Brain className="w-8 h-8 text-primary" />
                Generate Question
              </h2>
              
              <div className="grid gap-6 md:grid-cols-2 mb-6">
                <div>
                  <label className="block text-sm font-black uppercase tracking-wider mb-3">Topic</label>
                  {topicsLoading ? (
                    <div className="p-4 border-2 border-gray-200 bg-gray-50 text-gray-400 font-bold">Loading topics...</div>
                  ) : Object.keys(topics).length === 0 ? (
                    <div className="p-4 border-2 border-rose-200 bg-rose-50 text-rose-600 font-bold">No topics available.</div>
                  ) : (
                    <div className="grid grid-cols-2 gap-2 max-h-48 overflow-y-auto">
                      {Object.keys(topics).map((topic) => (
                        <button
                          key={topic}
                          onClick={() => setSelectedTopic(topic)}
                          className={`p-3 border-2 font-bold text-sm transition-all text-left ${
                            selectedTopic === topic
                              ? 'bg-primary text-white border-gray-900 shadow-[3px_3px_0px_0px_#000]'
                              : 'bg-white border-gray-200 hover:border-gray-900'
                          }`}
                        >
                          <span className="mr-2">{TOPIC_ICONS[topic] || '•'}</span>
                          {topic.replace('_', ' ')}
                        </button>
                      ))}
                    </div>
                  )}
                  {selectedTopic && topics[selectedTopic] && (
                    <div className="mt-3 p-3 bg-gray-50 border-2 border-gray-200 text-sm">
                      <p><span className="font-black">Patterns:</span> {topics[selectedTopic].patterns.slice(0, 3).join(', ')}</p>
                    </div>
                  )}
                </div>

                <div>
                  <label className="block text-sm font-black uppercase tracking-wider mb-3">Difficulty</label>
                  <div className="grid grid-cols-3 gap-2">
                    {difficultyLevels.map((level) => (
                      <button
                        key={level}
                        onClick={() => setSelectedDifficulty(level)}
                        className={`p-4 border-2 font-black uppercase text-sm transition-all ${
                          selectedDifficulty === level
                            ? 'bg-primary text-white border-gray-900 shadow-[3px_3px_0px_0px_#000]'
                            : 'bg-white border-gray-200 hover:border-gray-900'
                        }`}
                      >
                        {level}
                      </button>
                    ))}
                  </div>
                </div>
              </div>

              <button
                onClick={handleGenerate}
                disabled={generateMutation.isPending || !selectedTopic || !selectedDifficulty}
                className="w-full btn-brutalist py-4 text-lg flex items-center justify-center gap-2"
              >
                {generateMutation.isPending ? (
                  <><Loader2 className="w-5 h-5 animate-spin" /> Generating...</>
                ) : (
                  <><Zap className="w-5 h-5" /> Generate Question</>
                )}
              </button>
            </div>
          </FadeInUp>
        )}

        {/* Questions Tab - Use existing QuestionCard component */}
        {activeTab === 'questions' && (
          <FadeInUp>
            {questionsLoading ? (
              <div className="space-y-4">
                {[1, 2, 3].map((i) => <div key={i} className="brutalist-card h-32 animate-pulse bg-gray-100" />)}
              </div>
            ) : questions && questions.length > 0 ? (
              <div className="space-y-4">
                {questions.map((question) => (
                  <DSAQuestionCard
                    key={question.id}
                    question={question}
                    expandedHints={expandedHints}
                    showSolution={showSolution}
                    onToggleHint={(id) => {
                      setExpandedHints(prev => {
                        const next = new Set(prev);
                        if (next.has(id)) next.delete(id);
                        else next.add(id);
                        return next;
                      });
                    }}
                    onToggleSolution={(id) => {
                      setShowSolution(prev => {
                        const next = new Set(prev);
                        if (next.has(id)) next.delete(id);
                        else next.add(id);
                        return next;
                      });
                    }}
                    onMarkComplete={(id) => completeMutation.mutate(id)}
                    onDelete={(id) => deleteMutation.mutate(id)}
                    isUpdating={completeMutation.isPending}
                    isDeleting={deleteMutation.isPending}
                  />
                ))}
              </div>
            ) : (
              <div className="brutalist-card p-12 text-center">
                <div className="w-20 h-20 bg-gray-200 border-2 border-gray-900 flex items-center justify-center mx-auto mb-6">
                  <Code2 className="w-10 h-10 text-gray-400" />
                </div>
                <h3 className="text-2xl font-black mb-2">No questions yet</h3>
                <p className="text-gray-500 font-medium mb-6">Generate your first DSA question to start practicing</p>
                <button 
                  onClick={() => setActiveTab('practice')} 
                  className="btn-brutalist px-8 py-4 text-lg bg-primary text-white"
                >
                  Generate Your First Question
                </button>
              </div>
            )}
          </FadeInUp>
        )}

        {/* Analytics Tab */}
        {activeTab === 'analytics' && (
          <FadeInUp>
            {analyticsLoading ? (
              <div className="grid md:grid-cols-2 gap-6 animate-pulse">
                <div className="brutalist-card h-64 bg-gray-100" />
                <div className="brutalist-card h-64 bg-gray-100" />
              </div>
            ) : stats.total_questions_attempted === 0 ? (
              <div className="brutalist-card p-12 text-center">
                <BarChart3 className="w-12 h-12 mx-auto mb-4 text-gray-300" />
                <h3 className="text-xl font-black mb-2">No Data Yet</h3>
                <p className="text-gray-500 mb-6">Complete your first question to see analytics.</p>
                <button 
                  onClick={() => setActiveTab('practice')} 
                  className="btn-brutalist px-8 py-4 text-lg bg-primary text-white"
                >
                  Generate Your First Question
                </button>
              </div>
            ) : (
              <div className="grid md:grid-cols-2 gap-6">
              <div className="brutalist-card p-6 rounded-xl">
                <h3 className="text-xl font-black mb-4">Difficulty Distribution</h3>
                <div className="space-y-3">
                  {['easy', 'medium', 'hard'].map((diff) => (
                    <div key={diff} className="flex items-center gap-3">
                      <span className="w-20 font-black uppercase text-sm">{diff}</span>
                      <div className="flex-1 h-8 bg-gray-100 border-2 border-gray-200 relative">
                        <motion.div
                          initial={{ width: 0 }}
                          animate={{ width: `${stats.total_questions_attempted > 0 ? (stats.difficulty_distribution[diff as keyof typeof stats.difficulty_distribution] / stats.total_questions_attempted) * 100 : 0}%` }}
                          className={`h-full ${DIFFICULTY_STYLES[diff].split(' ')[0]}`}
                        />
                        <span className="absolute inset-0 flex items-center justify-center font-bold text-sm">
                          {stats.difficulty_distribution[diff as keyof typeof stats.difficulty_distribution]}
                        </span>
                      </div>
                    </div>
                  ))}
                </div>
              </div>

              <div className="brutalist-card p-6 rounded-xl">
                <h3 className="text-xl font-black mb-4">Topics Practiced</h3>
                <div className="flex flex-wrap gap-2">
                  {stats.topics_practiced.length > 0 ? stats.topics_practiced.map((topic) => (
                    <span key={topic} className="px-3 py-2 bg-primary/10 border-2 border-gray-900 font-bold text-sm">
                      {TOPIC_ICONS[topic] || '•'} {topic.replace('_', ' ')}
                    </span>
                  )) : (
                    <p className="text-gray-500 font-medium">No topics practiced yet</p>
                  )}
                </div>
              </div>
              </div>
            </div>
          </FadeInUp>
        )}
      </div>
    </div>
  );
}
